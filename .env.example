# ── LLM Provider (pick one) ──────────────────────────────────────
# Options: gemini | groq
LLM_PROVIDER=gemini

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# Groq — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Telegram (Step 2) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Knowledge layer ───────────────────────────────────────────────
# prototype: local markdown files in brain/
# production: swap to gbrain (see docs/PRODUCTION_MIGRATION.md)
KNOWLEDGE_PROVIDER=local
BRAIN_DIR=brain

# ── Vercel demo (optional) ────────────────────────────────────────
# Set to require password before client can use the chat UI
DEMO_PASSWORD=

# ── Production placeholders (not needed for demo) ───────────────────
# MANUS_API_KEY=
# ANTHROPIC_API_KEY=
# GBRAIN_URL=
# GBRAIN_TOKEN=
